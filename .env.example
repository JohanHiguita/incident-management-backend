# Plantilla de variables de entorno.
# 1. Copia este archivo:  cp .env.example .env
# 2. Ajusta los valores en .env (ese archivo NO se sube a Git).
# 3. Las credenciales deben coincidir con docker-compose.yml en la raíz del proyecto.

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/coordinadora_events

# API
PORT=3000
